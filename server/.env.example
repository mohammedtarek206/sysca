# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/academy_db

# JWT Secret - استخدم string عشوائي قوي
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Port (Vercel بتتجاهله - للتطوير المحلي فقط)
PORT=5000

# Frontend URL - لإعدادات CORS
CLIENT_URL=https://your-client-project.vercel.app
